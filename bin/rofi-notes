#!/usr/bin/env bash
# Author: Bruno Guimarães
# Description: Open quick notes in nvim through rofi
# Version: 1.0
# Last Updated: 2026-07-02

set -euo pipefail
IFS=$'\n\t'

readonly SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
source "$SCRIPT_DIR/lib/xdg.sh"
source "$SCRIPT_DIR/lib/rofi-theme.sh"
source "$SCRIPT_DIR/lib/rofi-file-picker.sh"

xdg_init
load_config

readonly NOTES_DIR="${ROFI_NOTES_DIR:-${ROFI_NOTE_DIR:-$APP_DATA_DIR/notes}}"

main() {
  mkdir -p "$NOTES_DIR"
  pick_and_open_file "$NOTES_DIR" flat
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
