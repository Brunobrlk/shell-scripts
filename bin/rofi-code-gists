#!/usr/bin/env bash
# Author: Bruno Guimarães
# Description: Copy code gist files to the clipboard or create a new one in nvim
# Version: 1.0
# Last Updated: 2026-07-02

set -euo pipefail
IFS=$'\n\t'

readonly SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
source "$SCRIPT_DIR/lib/xdg.sh"
source "$SCRIPT_DIR/lib/rofi-theme.sh"
source "$SCRIPT_DIR/lib/rofi-file-picker.sh"

xdg_init
load_config

readonly CODE_GISTS_DIR="${CODE_GISTS_DIR:-$APP_DATA_DIR/code-gists}"

main() {
  pick_copy_or_create_markdown_file "$CODE_GISTS_DIR"
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
