#!/usr/bin/env bash
# Author: Bruno Guimarães
# Description: Depends on: https://github.com/adi1090x/rofi
# Version: 1.0
# Last Updated: 2025-12-19

set -euo pipefail
IFS=$'\n\t'

# ──────────────────────────────────────────────────────────────────────────────
# Constants / Config
# ──────────────────────────────────────────────────────────────────────────────
# Import Rofi Theme
readonly SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
source "$SCRIPT_DIR/lib/xdg.sh"
source "$SCRIPT_DIR/lib/rofi-theme.sh"

xdg_init
load_config

readonly NOTES_DIR="${ROFI_NOTE_DIR:-$APP_DATA_DIR/notes}"

# ──────────────────────────────────────────────────────────────────────────────
# Functions
# ──────────────────────────────────────────────────────────────────────────────
open_on_nvim() {
  local file_path="$1"
  alacritty -o 'window.startup_mode="Fullscreen"' -e bash -lic "nvim '$file_path'"
}

# ──────────────────────────────────────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────────────────────────────────────
main() {
  mkdir -p "$NOTES_DIR"

  local choice
  choice=$(
    find "$NOTES_DIR" -maxdepth 1 -mindepth 1 -type f -printf '%f\n' | sort | rofi_cmd
  )
  [[ -z "$choice" ]] && exit 0
  open_on_nvim "$NOTES_DIR/$choice"
}

# ──────────────────────────────────────────────────────────────────────────────
# Entry Point
# ──────────────────────────────────────────────────────────────────────────────
# Only run main if script is executed (not sourced)
[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
