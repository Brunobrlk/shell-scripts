declare -A APPLIED_FEATURES=()

# ──────────────────────────────────────────────────────────────────────────────
# Functions
# ──────────────────────────────────────────────────────────────────────────────
require_file() {
  local file="$1"
  [[ -f "$file" ]] || {
    echo "Missing file: $file" >&2
    return 1
  }
}

validate_project_files() {
  require_file "$APP_BUILD"
  require_file "$ROOT_BUILD"
  require_file "$LIBS_FILE"
}

add_plugin() {
  local file="$1"
  local plugin_line="$2"

  if grep -qF "$plugin_line" "$file"; then
    return 0
  fi

  if grep -qE '^[[:space:]]*plugins[[:space:]]*\{' "$file"; then
    sed -i "/^[[:space:]]*plugins[[:space:]]*{/a \    $plugin_line" "$file"
  else
    {
      echo "plugins {"
      echo "    $plugin_line"
      echo "}"
      echo
      cat "$file"
    } >"${file}.tmp" && mv "${file}.tmp" "$file"
  fi
}

append_after() {
  local file="$1"
  local section="$2"
  local content="$3"

  if grep -qF "$content" "$file"; then
    return 0
  fi

  if ! grep -qE "^[[:space:]]*\\[$section\\][[:space:]]*$" "$file"; then
    echo "Missing section [$section] in $file" >&2
    return 1
  fi

  sed -i "/^[[:space:]]*\\[$section\\][[:space:]]*$/a $content" "$file"
}

add_dependency() {
  local file="$1"
  local lib_line="$2"

  if grep -qF "$lib_line" "$file"; then
    return 0
  fi

  if grep -qE '^[[:space:]]*dependencies[[:space:]]*\{' "$file"; then
    sed -i "/^[[:space:]]*dependencies[[:space:]]*{/a \    $lib_line" "$file"
  else
    printf '\n\ndependencies {\n    %s\n}\n' "$lib_line" >>"$file"
  fi
}

apply_lines() {
  local handler="$1"
  local file="$2"
  local lines="${3:-}"
  local section="${4:-}"
  local line

  [[ -z "$lines" ]] && return 0

  while IFS= read -r line; do
    [[ -z "$line" ]] && continue
    if [[ -n "$section" ]]; then
      "$handler" "$file" "$section" "$line"
    else
      "$handler" "$file" "$line"
    fi
  done <<<"$lines"
}

apply_feature() {
  local feature="$1"
  local dependency

  feature_exists "$feature" || {
    echo "Unknown feature: $feature" >&2
    return 1
  }

  if [[ "${APPLIED_FEATURES[$feature]:-0}" -eq 1 ]]; then
    return 0
  fi
  APPLIED_FEATURES["$feature"]=1

  while IFS= read -r dependency; do
    [[ -z "$dependency" ]] && continue
    apply_feature "$dependency"
  done <<<"${FEATURE_REQUIRES[$feature]:-}"

  apply_lines append_after "$LIBS_FILE" "${FEATURE_VERSIONS[$feature]:-}" "$VERSIONS_SECTION_PATTERN"
  apply_lines append_after "$LIBS_FILE" "${FEATURE_LIBRARIES[$feature]:-}" "$LIBS_SECTION_PATTERN"
  apply_lines append_after "$LIBS_FILE" "${FEATURE_CATALOG_PLUGINS[$feature]:-}" "$PLUGINS_SECTION_PATTERN"
  apply_root_plugins "${FEATURE_BUILD_PLUGINS[$feature]:-}"
  apply_lines add_plugin "$APP_BUILD" "${FEATURE_BUILD_PLUGINS[$feature]:-}"
  apply_lines add_dependency "$APP_BUILD" "${FEATURE_DEPENDENCIES[$feature]:-}"
}

feature_key() {
  local item="$1"
  printf '%s\n' "${item%%|*}"
}

feature_label() {
  local item="$1"
  printf '%s\n' "${item#*|}"
}

feature_exists() {
  local wanted="$1"
  local item

  for item in "${FEATURE_ITEMS[@]}"; do
    [[ "$(feature_key "$item")" == "$wanted" ]] && return 0
  done

  return 1
}

apply_root_plugins() {
  local plugins="${1:-}"
  local plugin_line

  [[ -z "$plugins" ]] && return 0

  while IFS= read -r plugin_line; do
    [[ -z "$plugin_line" ]] && continue
    add_plugin "$ROOT_BUILD" "$plugin_line apply false"
  done <<<"$plugins"
}

build_menu() {
  local item
  for item in "${FEATURE_ITEMS[@]}"; do
    feature_label "$item"
  done
}

feature_from_label() {
  local label="$1"
  local item

  for item in "${FEATURE_ITEMS[@]}"; do
    if [[ "$(feature_label "$item")" == "$label" ]]; then
      feature_key "$item"
      return 0
    fi
  done

  return 1
}

# ──────────────────────────────────────────────────────────────────────────────
# Main
# ──────────────────────────────────────────────────────────────────────────────
main() {
  local choice
  local feature

  validate_project_files

  choice="$(build_menu | rofi_cmd)"
  [[ -z "$choice" ]] && exit 0

  feature="$(feature_from_label "$choice")"
  apply_feature "$feature"
}

# ──────────────────────────────────────────────────────────────────────────────
# Entry Point
# ──────────────────────────────────────────────────────────────────────────────
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
  main "$@"
fi
