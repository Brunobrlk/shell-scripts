#!/usr/bin/env bash
# Author: Bruno Guimarães
# Description: Copy prompt files to the clipboard or create a new one in nvim
# Version: 1.0
# Last Updated: 2026-07-02

set -euo pipefail
IFS=$'\n\t'

readonly SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")/.." && pwd)"
source "$SCRIPT_DIR/lib/xdg.sh"
source "$SCRIPT_DIR/lib/rofi-theme.sh"
source "$SCRIPT_DIR/lib/rofi-file-picker.sh"

xdg_init
load_config

readonly PROMPTS_DIR="${PROMPT_LIBRARY_DIR:-$APP_DATA_DIR/prompts}"

main() {
  pick_copy_or_create_markdown_file "$PROMPTS_DIR"
}

[[ "${BASH_SOURCE[0]}" == "${0}" ]] && main "$@"
